{
  "manifest_version": 3,
  "name": "Network Download Administration",
  "version": "1.1",
  "description": "Download files with Network Download Administration",
  "permissions": ["contextMenus", "downloads", "activeTab"],
  "optional_permissions": ["cookies"],
  "optional_host_permissions": ["<all_urls>"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Network Download Administration",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nda@amritrajpathak",
      "strict_min_version": "109.0"
    }
  }
}