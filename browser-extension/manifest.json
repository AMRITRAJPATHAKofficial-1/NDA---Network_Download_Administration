{
  "manifest_version": 3.1,
  "name": "Network_Download_Administration",
  "version": "1.1",
  "description": "Send links to My Downloader desktop app",
  "permissions": ["contextMenus", "downloads", "activeTab"],
  "optional_permissions": ["cookies"],
  "optional_host_permissions": ["<all_urls>"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "My Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}